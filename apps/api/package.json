{
  "name": "@solocompass/api",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "node dist/index.js",
    "build": "tsc",
    "typecheck": "tsc --noEmit",
    "lint": "eslint src --ext .ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "db:migrate": "tsx src/lib/migrate.ts",
    "db:seed": "tsx src/lib/seed.ts",
    "db:studio": "drizzle-kit studio",
    "clean": "rm -rf dist"
  },
  "dependencies": {
    "@solocompass/config": "workspace:*",
    "@solocompass/types": "workspace:*",
    "@supabase/supabase-js": "^2.104.0",
    "cors": "^2.8.5",
    "dotenv": "^16.6.1",
    "drizzle-orm": "^0.36.4",
    "express": "^4.21.1",
    "helmet": "^7.1.0",
    "morgan": "^1.10.0",
    "pino": "^9.4.0",
    "pino-pretty": "^11.2.0",
    "postgres": "^3.4.9",
    "socket.io": "^4.8.1",
    "zod": "^3.23.8"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/morgan": "^1.9.9",
    "@types/node": "^20.11.0",
    "drizzle-kit": "^0.28.1",
    "eslint": "^9.15.0",
    "tsx": "^4.19.2",
    "typescript": "^5.3.3",
    "vitest": "^2.1.8"
  }
}